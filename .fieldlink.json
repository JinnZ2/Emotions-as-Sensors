{
  "fieldlink": {
    "version": "1.2",
    "updated": "2026-03-24T00:00:00Z",

    "role": ["sensors", "protocols", "shapes", "hub"],

    "sources": [
      {
        "name": "rosetta",
        "repo": "https://github.com/JinnZ2/Rosetta-Shape-Core",
        "ref": "main",
        "paths": [
          "shapes/*.json",
          "bridges/rosetta-bridges.json",
          "data/seed-catalog.json",
          "ontology/_id_registry.json",
          "ontology/_vocab.json"
        ],
        "mounts": [
          { "remote": "bridges/rosetta-bridges.json", "as": "atlas/remote/rosetta/bridges.json" },
          { "remote": "shapes/tetrahedron.json", "as": "atlas/remote/rosetta/shapes/tetrahedron.json" },
          { "remote": "shapes/cube.json", "as": "atlas/remote/rosetta/shapes/cube.json" },
          { "remote": "shapes/octahedron.json", "as": "atlas/remote/rosetta/shapes/octahedron.json" },
          { "remote": "shapes/dodecahedron.json", "as": "atlas/remote/rosetta/shapes/dodecahedron.json" },
          { "remote": "shapes/icosahedron.json", "as": "atlas/remote/rosetta/shapes/icosahedron.json" },
          { "remote": "data/seed-catalog.json", "as": "atlas/remote/rosetta/seed-catalog.json" },
          { "remote": "ontology/_id_registry.json", "as": "atlas/remote/rosetta/id-registry.json" },
          { "remote": "ontology/_vocab.json", "as": "atlas/remote/rosetta/vocab.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "biogrid",
        "repo": "https://github.com/JinnZ2/BioGrid2.0",
        "ref": "main",
        "paths": [
          "planned/glyphs/atlas.json",
          "registry/atlas.glyphs.json"
        ],
        "mounts": [
          { "remote": "planned/glyphs/atlas.json", "as": "atlas/remote/biogrid/planned.json" },
          { "remote": "registry/atlas.glyphs.json", "as": "atlas/remote/biogrid/registry.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "emotions",
        "repo": "https://github.com/JinnZ2/Emotions-as-Sensors",
        "ref": "main",
        "paths": [
          "atlas/emotions.json",
          "glyphs/emotion.glyphs.json"
        ],
        "mounts": [
          { "remote": "atlas/emotions.json", "as": "atlas/remote/emotions/atlas.json" },
          { "remote": "glyphs/emotion.glyphs.json", "as": "atlas/remote/emotions/glyphs.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      }
    ],

    "local_manifests": [
      "glyphs/**",
      "protocols/**",
      "sensors/**",
      "atlas/shapes.json"
    ],

    "merge": {
      "order": ["local", "rosetta", "emotions", "biogrid"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",

    "integrity": {
      "enabled": false,
      "hash": "sha256",
      "allow_missing": true
    },

    "consent": {
      "license": "CC-BY-4.0",
      "share_ok": true,
      "redact_rules": ["**/private/**", "*.secrets.json"]
    }
  }
}
