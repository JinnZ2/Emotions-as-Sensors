{
  "fieldlink": {
    "version": "1.2",
    "updated": "2026-03-24T00:00:00Z",

    "role": ["sensors", "protocols", "shapes", "hub"],

    "sources": [
      {
        "name": "rosetta",
        "repo": "https://github.com/JinnZ2/Rosetta-Shape-Core",
        "ref": "main",
        "paths": [
          "shapes/*.json",
          "bridges/rosetta-bridges.json",
          "data/seed-catalog.json",
          "ontology/_id_registry.json",
          "ontology/_vocab.json"
        ],
        "mounts": [
          { "remote": "bridges/rosetta-bridges.json", "as": "atlas/remote/rosetta/bridges.json" },
          { "remote": "shapes/tetrahedron.json", "as": "atlas/remote/rosetta/shapes/tetrahedron.json" },
          { "remote": "shapes/cube.json", "as": "atlas/remote/rosetta/shapes/cube.json" },
          { "remote": "shapes/octahedron.json", "as": "atlas/remote/rosetta/shapes/octahedron.json" },
          { "remote": "shapes/dodecahedron.json", "as": "atlas/remote/rosetta/shapes/dodecahedron.json" },
          { "remote": "shapes/icosahedron.json", "as": "atlas/remote/rosetta/shapes/icosahedron.json" },
          { "remote": "data/seed-catalog.json", "as": "atlas/remote/rosetta/seed-catalog.json" },
          { "remote": "ontology/_id_registry.json", "as": "atlas/remote/rosetta/id-registry.json" },
          { "remote": "ontology/_vocab.json", "as": "atlas/remote/rosetta/vocab.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "biogrid",
        "repo": "https://github.com/JinnZ2/BioGrid2.0",
        "ref": "main",
        "paths": [
          "planned/glyphs/atlas.json",
          "registry/atlas.glyphs.json"
        ],
        "mounts": [
          { "remote": "planned/glyphs/atlas.json", "as": "atlas/remote/biogrid/planned.json" },
          { "remote": "registry/atlas.glyphs.json", "as": "atlas/remote/biogrid/registry.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "emotions",
        "repo": "https://github.com/JinnZ2/Emotions-as-Sensors",
        "ref": "main",
        "direction": "bidirectional",
        "paths": [
          "atlas/emotions.json",
          "glyphs/emotion.glyphs.json",
          "sensors/shapes/*.json",
          "sensors/decay-families.json",
          "sensors/glyph-map.json"
        ],
        "exports": [
          { "local": "atlas/emotions.json",        "description": "Sensor atlas with decay families and shape linkages" },
          { "local": "glyphs/emotion.glyphs.json",  "description": "Glyph registry with family groupings" },
          { "local": "sensors/shapes/*.json",        "description": "Operationalized shape definitions" },
          { "local": "sensors/decay-families.json",  "description": "Decay family taxonomy" },
          { "local": "sensors/glyph-map.json",       "description": "Sensor-to-glyph symbolic mappings" }
        ],
        "mounts": [
          { "remote": "atlas/emotions.json", "as": "atlas/remote/emotions/atlas.json" },
          { "remote": "glyphs/emotion.glyphs.json", "as": "atlas/remote/emotions/glyphs.json" }
        ],
        "consent": { "license": "CC0-1.0", "share_ok": true }
      },
      {
        "name": "inversion",
        "repo": "https://github.com/JinnZ2/Inversion",
        "ref": "main",
        "direction": "bidirectional",
        "paths": [
          "sims/systems_dynamics.py",
          "sims/dissipative_systems.py",
          "scripts/validation_framework.py",
          "scripts/contamination_detector.py",
          "Survival.md"
        ],
        "exports": [
          { "local": "atlas/emotions.json",                 "description": "Sensor atlas with PAD coordinates for corruption detection" },
          { "local": "sensors/suite/comprehensive.json",    "description": "Full sensor suite for distributed sensing" },
          { "local": "src/constraint_agent.py",             "description": "Constraint agent with tier-based prioritization" }
        ],
        "mounts": [
          { "remote": "sims/systems_dynamics.py",           "as": "atlas/remote/inversion/systems_dynamics.py" },
          { "remote": "sims/dissipative_systems.py",        "as": "atlas/remote/inversion/dissipative_systems.py" },
          { "remote": "scripts/validation_framework.py",    "as": "atlas/remote/inversion/validation_framework.py" },
          { "remote": "scripts/contamination_detector.py",  "as": "atlas/remote/inversion/contamination_detector.py" }
        ],
        "consent": { "license": "CC0-1.0", "share_ok": true }
      }
    ],

    "local_manifests": [
      "glyphs/**",
      "protocols/**",
      "sensors/**",
      "atlas/shapes.json"
    ],

    "merge": {
      "order": ["local", "rosetta", "emotions", "inversion", "biogrid"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",

    "integrity": {
      "enabled": false,
      "hash": "sha256",
      "allow_missing": true
    },

    "consent": {
      "license": "CC-BY-4.0",
      "share_ok": true,
      "redact_rules": ["**/private/**", "*.secrets.json"]
    }
  }
}
